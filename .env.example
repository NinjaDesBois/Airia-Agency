# Airia — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# ─── IA / Anthropic ──────────────────────────────────────────────────────────
# Clé API serveur — utilisée par /api/chat.js et /api/demo.js (côté serveur uniquement)
ANTHROPIC_API_KEY=your_key

# ─── Voix IA / Vapi.ai ───────────────────────────────────────────────────────
# Clé publique Vapi (safe côté client, préfixe VITE_ obligatoire)
VITE_VAPI_API_KEY=your_vapi_key

# ─── Paiements ───────────────────────────────────────────────────────────────
# Stripe (marché international)
STRIPE_SECRET_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Mollie (marché belge — alternative recommandée)
MOLLIE_API_KEY=your_mollie_key

# ─── Intégrations externes ───────────────────────────────────────────────────
# Lien Calendly pour les appels stratégiques
VITE_CALENDLY_URL=your_calendly_url
